Date: Wed, 8 Apr 2026 17:35:16 -0700
Subject: [PATCH] Avoid example symlinks in the staged Python package

Replace example-tree symlinks with direct references in CMake and Sphinx so the examples directory can be copied on Windows without duplicating those files in git.
---
 examples/CMakeLists.txt                     | 12 ++++++------
 examples/fodo_programmable/README.rst       |  8 ++++----
 examples/fodo_programmable/analysis_fodo.py |  1 -
 examples/fodo_programmable/plot_fodo.py     |  1 -
 examples/fodo_userdef/README.rst            |  8 ++++----
 examples/fodo_userdef/analysis_fodo.py      |  1 -
 examples/fodo_userdef/plot_fodo.py          |  1 -
 examples/optimize_triplet/README.rst        |  2 +-
 examples/optimize_triplet/test_xopt.py      |  1 -
 9 files changed, 15 insertions(+), 20 deletions(-)
 delete mode 120000 examples/fodo_programmable/analysis_fodo.py
 delete mode 120000 examples/fodo_programmable/plot_fodo.py
 delete mode 120000 examples/fodo_userdef/analysis_fodo.py
 delete mode 120000 examples/fodo_userdef/plot_fodo.py
 delete mode 120000 examples/optimize_triplet/test_xopt.py

diff --git a/examples/CMakeLists.txt b/examples/CMakeLists.txt
index 2d54daa6..bc1db181 100644
--- a/examples/CMakeLists.txt
+++ b/examples/CMakeLists.txt
@@ -289,8 +289,8 @@ add_impactx_test(FODO-exact.py
 add_impactx_test(FODO.programmable.py
     examples/fodo_programmable/run_fodo_programmable.py
     OFF  # ImpactX MPI-parallel
-    examples/fodo_programmable/analysis_fodo.py
-    examples/fodo_programmable/plot_fodo.py
+    examples/fodo/analysis_fodo.py
+    examples/fodo/plot_fodo.py
 )
 
 # Python: Change Elements Per Turn ############################################
@@ -321,14 +321,14 @@ add_impactx_test(FODO.MADX.py
 add_impactx_test(FODO.userdef
     examples/fodo_userdef/input_fodo_userdef.in
     ON   # ImpactX MPI-parallel
-    examples/fodo_userdef/analysis_fodo.py
-    examples/fodo_userdef/plot_fodo.py
+    examples/fodo/analysis_fodo.py
+    examples/fodo/plot_fodo.py
 )
 add_impactx_test(FODO.userdef.py
     examples/fodo_userdef/run_fodo_userdef.py
     OFF  # ImpactX MPI-parallel
-    examples/fodo_userdef/analysis_fodo.py
-    examples/fodo_userdef/plot_fodo.py
+    examples/fodo/analysis_fodo.py
+    examples/fodo/plot_fodo.py
 )
 
 
