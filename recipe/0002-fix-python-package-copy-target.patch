From d92cd42f7c92c4d5ea6c4e5535c4c7ccbdd7a4a3 Mon Sep 17 00:00:00 2001
From: Axel Huebl <axel.huebl@plasma.ninja>
Date: Wed, 8 Apr 2026 14:38:10 -0700
Subject: [PATCH] Fix Windows Python Install

The contained symlink to `examples` for the dashboard broke
CMake's `copy_directory` on Windows (seen on conda-forge).
The logic was also tied to the link step via `POST_BUILD` and
is now decoupled.

Now stages examples explicitly into the build-tree Python
package from the repo-root examples directory.

Also update the dashboard example loader to resolve examples from the
packaged layout first and fall back to the repo-root tree for
source-tree development.
---
 CMakeLists.txt                                | 16 ++++++++--
 .../Toolbar/examples_loader/loader.py         | 29 +++++++++----------
 src/python/impactx/examples                   |  1 -
 3 files changed, 27 insertions(+), 19 deletions(-)
 delete mode 120000 src/python/impactx/examples

diff --git a/CMakeLists.txt b/CMakeLists.txt
index f5308aab..7a32e5c8 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -493,11 +493,21 @@ if(ImpactX_PYTHON)
             ${ImpactX_CUSTOM_TARGET_PREFIX}pip_wheel
     )
 
-    # copy Python wrapper library to build directory
-    add_custom_command(TARGET pyImpactX POST_BUILD
+    # populate the build-tree Python package for ctest and direct build-tree imports
+    add_custom_target(pyImpactX_python_sources ALL
+        COMMAND ${CMAKE_COMMAND} -E make_directory
+            ${CMAKE_PYTHON_OUTPUT_DIRECTORY}
         COMMAND ${CMAKE_COMMAND} -E copy_directory
             ${ImpactX_SOURCE_DIR}/src/python/impactx
-            $<TARGET_FILE_DIR:pyImpactX>
+            ${CMAKE_PYTHON_OUTPUT_DIRECTORY}/impactx
+        COMMAND ${CMAKE_COMMAND} -E copy_directory
+            ${ImpactX_SOURCE_DIR}/examples
+            ${CMAKE_PYTHON_OUTPUT_DIRECTORY}/impactx/examples
+        VERBATIM
+    )
+    add_dependencies(pyImpactX_python_sources pyImpactX)
+    add_dependencies(${ImpactX_CUSTOM_TARGET_PREFIX}pip_wheel
+        pyImpactX_python_sources
     )
 endif()
 
diff --git a/src/python/impactx/dashboard/Toolbar/examples_loader/loader.py b/src/python/impactx/dashboard/Toolbar/examples_loader/loader.py
index 7a7412e7..3b3f15b7 100644
--- a/src/python/impactx/dashboard/Toolbar/examples_loader/loader.py
+++ b/src/python/impactx/dashboard/Toolbar/examples_loader/loader.py
@@ -42,22 +42,21 @@ class DashboardExamplesLoader:
                 populate_impactx_simulation_file_to_ui(example_script)
 
     @staticmethod
-    def get_impactx_path() -> Path:
+    def get_examples_directory() -> Path:
         """
-        Helper method to find the impactx/examples parent directory.
-        For now, just utilized to load the file names of the impactx examples
-        and retrieve the script in string format.
-        Potentially, this could be used to locate other impactx directories.
+        Return the packaged examples directory when available, otherwise fall
+        back to the repo-root examples tree for source-tree development.
         """
 
-        current_directory = Path(__file__).resolve()
+        packaged_examples = IMPACTX_PYTHON_ROOT / "examples"
+        if packaged_examples.is_dir():
+            return packaged_examples
 
-        for parent in current_directory.parents:
-            desired_path = parent / "examples"
-            if parent.name == "impactx" and desired_path.is_dir():
-                return parent
+        repo_examples = IMPACTX_PYTHON_ROOT.parents[2] / "examples"
+        if repo_examples.is_dir():
+            return repo_examples
 
-        return None
+        raise FileNotFoundError("Unable to locate ImpactX examples directory")
 
     @staticmethod
     def _get_example_content(file_name: str) -> dict:
@@ -65,8 +64,9 @@ class DashboardExamplesLoader:
         Retrieve the selected ImpactX example file and populate the UI with its values.
         """
 
-        impactx_directory = IMPACTX_PYTHON_ROOT
-        impactx_example_file_path = impactx_directory / "examples" / file_name
+        impactx_example_file_path = (
+            DashboardExamplesLoader.get_examples_directory() / file_name
+        )
 
         file_content_as_str = impactx_example_file_path.read_text()
         file_dict = {"content": file_content_as_str.encode("utf-8")}
@@ -82,8 +82,7 @@ class DashboardExamplesLoader:
 
         state.impactx_example_list.clear()
 
-        impactx_directory = DashboardExamplesLoader.get_impactx_path()
-        impactx_examples_directory = impactx_directory / "examples"
+        impactx_examples_directory = DashboardExamplesLoader.get_examples_directory()
 
         for path in impactx_examples_directory.glob("**/run*"):
             relative_path = path.relative_to(impactx_examples_directory)
diff --git a/src/python/impactx/examples b/src/python/impactx/examples
deleted file mode 120000
index 9f9d1de8..00000000
--- a/src/python/impactx/examples
+++ /dev/null
@@ -1 +0,0 @@
-../../../examples
\ No newline at end of file
