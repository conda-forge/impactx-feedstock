diff --git a/CMakeLists.txt b/CMakeLists.txt
index f5308aab..66ebfe8a 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -493,11 +493,64 @@ if(ImpactX_PYTHON)
             ${ImpactX_CUSTOM_TARGET_PREFIX}pip_wheel
     )
 
-    # copy Python wrapper library to build directory
-    add_custom_command(TARGET pyImpactX POST_BUILD
-        COMMAND ${CMAKE_COMMAND} -E copy_directory
-            ${ImpactX_SOURCE_DIR}/src/python/impactx
-            $<TARGET_FILE_DIR:pyImpactX>
+    # populate the build-tree Python package for ctest and direct build-tree imports
+    set(pyImpactX_python_pkg_dir "${CMAKE_PYTHON_OUTPUT_DIRECTORY}/impactx")
+    file(GLOB_RECURSE pyImpactX_python_source_files
+        CONFIGURE_DEPENDS
+        LIST_DIRECTORIES FALSE
+        RELATIVE "${ImpactX_SOURCE_DIR}/src/python/impactx"
+        "${ImpactX_SOURCE_DIR}/src/python/impactx/*"
+    )
+    # The package-level examples entry is a symlink in the source tree; copy the
+    # actual files from the repo-root examples directory explicitly below.
+    list(FILTER pyImpactX_python_source_files EXCLUDE REGEX "^examples$")
+    file(GLOB_RECURSE pyImpactX_example_files
+        CONFIGURE_DEPENDS
+        LIST_DIRECTORIES FALSE
+        RELATIVE "${ImpactX_SOURCE_DIR}/examples"
+        "${ImpactX_SOURCE_DIR}/examples/*"
+    )
+    set(pyImpactX_python_copy_script
+        "${CMAKE_CURRENT_BINARY_DIR}/pyImpactX_python_sources.cmake"
+    )
+    set(pyImpactX_python_copy_script_content
+        "file(MAKE_DIRECTORY [=[${pyImpactX_python_pkg_dir}]=])\n"
+    )
+    set(pyImpactX_examples_pkg_dir "${pyImpactX_python_pkg_dir}/examples")
+    foreach(pyImpactX_python_source_file IN LISTS pyImpactX_python_source_files)
+        get_filename_component(
+            pyImpactX_python_source_dir
+            "${pyImpactX_python_source_file}"
+            DIRECTORY
+        )
+        if(pyImpactX_python_source_dir)
+            string(APPEND pyImpactX_python_copy_script_content
+                "file(MAKE_DIRECTORY [=[${pyImpactX_python_pkg_dir}/${pyImpactX_python_source_dir}]=])\n"
+            )
+        endif()
+        string(APPEND pyImpactX_python_copy_script_content
+            "execute_process(\n"
+            "    COMMAND [=[${CMAKE_COMMAND}]=] -E copy_if_different\n"
+            "        [=[${ImpactX_SOURCE_DIR}/src/python/impactx/${pyImpactX_python_source_file}]=]\n"
+            "        [=[${pyImpactX_python_pkg_dir}/${pyImpactX_python_source_file}]=]\n"
+            "    COMMAND_ERROR_IS_FATAL ANY\n"
+            ")\n"
+        )
+    endforeach()
+    string(APPEND pyImpactX_python_copy_script_content
+        "file(MAKE_DIRECTORY [=[${pyImpactX_examples_pkg_dir}]=])\n"
+    )
+    foreach(pyImpactX_example_file IN LISTS pyImpactX_example_files)
+        get_filename_component(
+            pyImpactX_example_dir
+            "${pyImpactX_example_file}"
+            DIRECTORY
+        )
+        if(pyImpactX_example_dir)
+            string(APPEND pyImpactX_python_copy_script_content
+                "file(MAKE_DIRECTORY [=[${pyImpactX_examples_pkg_dir}/${pyImpactX_example_dir}]=])\n"
+            )
+        endif()
+        string(APPEND pyImpactX_python_copy_script_content
+            "execute_process(\n"
+            "    COMMAND [=[${CMAKE_COMMAND}]=] -E copy_if_different\n"
+            "        [=[${ImpactX_SOURCE_DIR}/examples/${pyImpactX_example_file}]=]\n"
+            "        [=[${pyImpactX_examples_pkg_dir}/${pyImpactX_example_file}]=]\n"
+            "    COMMAND_ERROR_IS_FATAL ANY\n"
+            ")\n"
+        )
+    endforeach()
+    file(WRITE
+        "${pyImpactX_python_copy_script}"
+        "${pyImpactX_python_copy_script_content}"
+    )
+    add_custom_target(pyImpactX_python_sources ALL
+        COMMAND ${CMAKE_COMMAND} -P "${pyImpactX_python_copy_script}"
+        VERBATIM
     )
 endif()
 
